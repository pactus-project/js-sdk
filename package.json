{
  "name": "@pactus/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for creating, managing, and interacting with Pactus blockchain wallets",
  "license": "MIT",
  "author": "Pactus blockchain",
  "homepage": "https://github.com/pactus-project/js-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pactus-project/js-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/pactus-project/js-sdk/issues"
  },
  "keywords": [
    "pactus",
    "wallet",
    "blockchain",
    "sdk",
    "crypto",
    "typescript"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@trustwallet/wallet-core": "^4.3.1",
    "argon2-browser": "^1.18.0",
    "bech32": "^2.0.0",
    "bip39": "^3.1.0",
    "pactus-jsonrpc": "^1.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@types/argon2-browser": "^1.18.4",
    "@types/jest": "^29.5",
    "@types/long": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.0.0",
    "fake-indexeddb": "6.0.1",
    "glob": "^11.1.0",
    "globals": "^16.0.0",
    "jest": "^29.7",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1",
    "typescript": "~5.5.3",
    "typescript-eslint": "^8.0.0",
    "webextension-polyfill": "^0.10.0"
  },
  "engines": {
    "node": ">=18"
  }
}
